# ============================================================================
# .env.example - Multi-Tenant ERP Configuration
# ============================================================================
# Copy this to .env and fill in your actual values
# NEVER commit .env to version control - add to .gitignore
#
# Usage in code:
#   import os
#   DB_HOST = os.getenv("MASTER_DB_HOST", "localhost")

# ============================================================================
# MASTER DATABASE (Centralized Tenant Registry)
# ============================================================================
# This database stores:
# - Tenant metadata (business name, email, credentials)
# - Audit logs (login attempts, schema changes)
# - Admin configuration

MASTER_DB_HOST=localhost
MASTER_DB_USER=root
MASTER_DB_PASSWORD=ashiq
MASTER_DB_NAME=erp_master_trivsys
MASTER_DB_PORT=3306

# ============================================================================
# TENANT DATABASE TEMPLATE
# ============================================================================
# New tenants inherit these credentials
# In production, consider using different users per tenant for extra isolation

TENANT_DB_HOST=localhost
TENANT_DB_USER=root
TENANT_DB_PASSWORD=ashiq
TENANT_DB_PORT=3306

# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================

STREAMLIT_LOGGER_LEVEL=warning
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=false
STREAMLIT_SERVER_MAXUPLOADSIZE=10

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Connection pool sizes
POOL_SIZE=500
POOL_MAX_OVERFLOW=1000
POOL_RECYCLE_SECONDS=3600

# Session timeouts
SESSION_TIMEOUT_MINUTES=30
TOKEN_EXPIRY_HOURS=24

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Password requirements
MIN_PASSWORD_LENGTH=12
REQUIRE_SPECIAL_CHARS=true
REQUIRE_NUMBERS=true

# Session security
USE_SSL=false  # Set to true in production
SECURE_COOKIES=false  # Set to true with HTTPS

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/erp_app.log
ENABLE_SQL_LOGGING=false  # Set to true for debugging (performance impact!)

# ============================================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================================

ENVIRONMENT=development  # development, staging, production
DEBUG_MODE=true
ALLOW_SIGNUP=true

# ============================================================================
# OPTIONAL: MULTI-REGION SUPPORT (Future)
# ============================================================================
# Route different tenant regions to different databases

PRIMARY_REGION_DB_HOST=localhost
PRIMARY_REGION_DB_NAME=erp_master
SECONDARY_REGION_DB_HOST=localhost-replica
SECONDARY_REGION_DB_NAME=erp_master_replica

# ============================================================================
# OPTIONAL: BACKUP & RESTORE
# ============================================================================

BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily (cron format)
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups/erp

# ============================================================================
# PROJECT STRUCTURE
# ============================================================================
#
# erp_multitenant_app/
# ├── .env                          # ← Your actual secrets (gitignored)
# ├── .env.example                  # ← Template (committed)
# ├── .gitignore                    # See below
# ├── requirements.txt              # Python dependencies
# ├── README.md                     # Project documentation
# │
# ├── database.py                   # Multi-tenant database manager
# ├── models.py                     # SQLAlchemy models (optional)
# ├── utils.py                      # Helper functions
# │
# ├── app.py                        # Main Streamlit app (entry point)
# │
# ├── pages/
# │   ├── 01_login.py
# │   ├── 02_products.py
# │   ├── 03_orders.py
# │   └── 04_settings.py            # (if using multi-page app)
# │
# ├── logs/
# │   └── erp_app.log
# │
# └── docs/
#     ├── SETUP.md                  # This guide
#     ├── API.md
#     └── DEPLOYMENT.md
#
# ============================================================================
# .gitignore
# ============================================================================
#
# # Environment variables (NEVER commit secrets!)
# .env
# .env.local
# .env.*.local
#
# # Python
# __pycache__/
# *.py[cod]
# *$py.class
# *.so
# .Python
# build/
# develop-eggs/
# dist/
# downloads/
# eggs/
# .eggs/
# lib/
# lib64/
# parts/
# sdist/
# var/
# wheels/
# *.egg-info/
# .installed.cfg
# *.egg
#
# # Virtual Environment
# venv/
# ENV/
# env/
#
# # IDE
# .vscode/
# .idea/
# *.swp
# *.swo
# *~
# .DS_Store
#
# # Logs
# logs/
# *.log
#
# # Database
# *.db
# *.sqlite
#
# # Streamlit
# .streamlit/
#
# ============================================================================
# QUICK START SETUP SCRIPT
# ============================================================================
#
# Save as setup.sh and run: chmod +x setup.sh && ./setup.sh
#
# #!/bin/bash
# 
# # 1. Create Python virtual environment
# python3.10 -m venv venv
# source venv/bin/activate  # On Windows: venv\Scripts\activate
#
# # 2. Install dependencies
# pip install --upgrade pip
# pip install -r requirements.txt
#
# # 3. Create .env from template
# cp .env.example .env
# echo "✅ Created .env file - update with your database credentials"
#
# # 4. Create logs directory
# mkdir -p logs
#
# # 5. Initialize database
# python -c "from database import initialize_master_db; initialize_master_db()"
# echo "✅ Master database initialized"
#
# # 6. Run Streamlit app
# streamlit run app.py
#
# ============================================================================
# DOCKER SETUP (Optional)
# ============================================================================
#
# Save as Dockerfile:
#
# FROM python:3.10-slim
# WORKDIR /app
# COPY requirements.txt .
# RUN pip install --no-cache-dir -r requirements.txt
# COPY . .
# EXPOSE 8501
# CMD ["streamlit", "run", "app.py"]
#
# Build: docker build -t erp-multitenant .
# Run:   docker run -p 8501:8501 --env-file .env erp-multitenant
#
# ============================================================================
# ENVIRONMENT-SPECIFIC CONFIGS
# ============================================================================
#
# Development (.env.development):
# ENVIRONMENT=development
# DEBUG_MODE=true
# ALLOW_SIGNUP=true
# ENABLE_SQL_LOGGING=true
# SECURE_COOKIES=false
#
# Staging (.env.staging):
# ENVIRONMENT=staging
# DEBUG_MODE=false
# ALLOW_SIGNUP=false  # Only admins create tenants
# ENABLE_SQL_LOGGING=false
# SECURE_COOKIES=true
#
# Production (.env.production):
# ENVIRONMENT=production
# DEBUG_MODE=false
# ALLOW_SIGNUP=false
# ENABLE_SQL_LOGGING=false
# SECURE_COOKIES=true
# USE_SSL=true
# SESSION_TIMEOUT_MINUTES=15
#
# ============================================================================
